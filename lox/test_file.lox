class Vehicle{
	init() {
		print "init";
		// return;
	}

	peep(){
		print "vehicle peeping";
	}
}

print Vehicle;
print Vehicle();

class Car < Vehicle {
	init(name) {
		this.name = name;
		super.init();
		print "hi " + name;
	}

	peep(){
		super.peep();
		print "car: Beep Beep";
	}
}

print Car("lambo");
Car("mclaren").peep();

